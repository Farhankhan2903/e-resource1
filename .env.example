# Port the backend server will run on
PORT=4000

# Database Configuration
# For local development, use localhost or 127.0.0.1
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=password
DB_NAME=eresourse_db

# JWT Secret for authentication
# This should be a long, random string in production
JWT_SECRET=eresource_super_secret_key_2026

# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY
